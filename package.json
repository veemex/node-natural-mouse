{
  "name": "natural-mouse-motion",
  "version": "2.0.0",
  "description": "Human-like mouse movement generation for Node.js — pluggable, async, zero native deps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mouse",
    "movement",
    "human",
    "natural",
    "cursor",
    "automation"
  ],
  "homepage": "https://github.com/veemex/node-natural-mouse",
  "author": "Trofin Cosmin Mihai",
  "repository": {
    "type": "git",
    "url": "git://github.com/veemex/node-natural-mouse.git"
  },
  "license": "MIT",
  "devDependencies": {
    "robotjs": "^0.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}